{
  "version": 2,
  "builds": [
    {
      "src": "backend/vercel_app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/vercel_app.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1",
    "DB_HOST": "sql.freedb.tech",
    "DB_PORT": "3306",
    "DB_NAME": "freedb_memory_management",
    "DB_USER": "freedb_memos",
    "DB_PASSWORD": "Nw2E3kDkv#6hb5U"
  }
}
